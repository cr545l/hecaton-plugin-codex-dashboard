{
  "id": "codex-dashboard",
  "name": "Codex Dashboard",
  "version": "1.0.1",
  "entry": "main.js",
  "runtime": "deno",
  "apiVersion": { "major": 1, "minor": 0 },
  "shortcut": { "key": "E", "mod": "ctrl+shift" },
  "overlay": {
    "mode": "floating",
    "width": "70%",
    "height": "70%",
    "z_order": 50,
    "resizable": false,
    "bordered": false,
    "minimized_label": "Codex",
    "minimized_label_color": "#968CE1"
  }
}
